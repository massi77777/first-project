      ],
      "source": [
        "# Find the optimal threshold to maximize F1 for the dropout class\n",
        "thresholds = np.arange(0.20, 0.70, 0.01)\n",
        "f1_scores  = [f1_score(y_test, (best_proba >= t).astype(int)) for t in thresholds]\n",
        "best_thresh = thresholds[np.argmax(f1_scores)]\n",
        "best_f1_tuned = max(f1_scores)\n",
        "\n",
        "plt.figure(figsize=(9,4))\n",
        "plt.plot(thresholds, f1_scores, 'b-', lw=2)\n",
        "plt.axvline(best_thresh, color='red', linestyle='--', label=f'Best Threshold = {best_thresh:.2f}')\n",
        "plt.xlabel('Threshold'); plt.ylabel('F1 Score (Dropout class)')\n",
        "plt.title('Threshold Tuning — Optimizing Dropout F1'); plt.legend(); plt.tight_layout(); plt.show()\n",
        "\n",
        "y_pred_tuned = (best_proba >= best_thresh).astype(int)\n",
        "print(f'Default threshold (0.50) → F1-dropout: {f1_score(y_test, best_pred):.4f}')\n",
        "print(f'Tuned  threshold ({best_thresh:.2f}) → F1-dropout: {best_f1_tuned:.4f}')\n",
