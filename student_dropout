      "source": [
        "results = {}\n",
        "\n",
        "def evaluate(name, pipeline, X_te, y_te, store=True):\n",
        "    y_pred  = pipeline.predict(X_te)\n",
        "    y_proba = pipeline.predict_proba(X_te)[:, 1]\n",
        "    metrics = {\n",
        "        'Accuracy' : accuracy_score(y_te, y_pred),\n",
        "        'Precision': precision_score(y_te, y_pred, average='weighted'),\n",
        "        'Recall'   : recall_score(y_te, y_pred, average='weighted'),\n",
        "        'F1-weighted': f1_score(y_te, y_pred, average='weighted'),\n",
        "        'F1-dropout' : f1_score(y_te, y_pred),          # binary (dropout class)\n",
        "        'ROC-AUC'  : roc_auc_score(y_te, y_proba)\n",
        "    }\n",
        "    if store:\n",
        "        results[name] = metrics\n",
        "    return metrics, y_pred, y_proba"
      ]
    },
