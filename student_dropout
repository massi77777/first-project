        "\n",
        "def predict_student(age, cgpa, semester_gpa, study_h, delay, attendance, travel,\n",
        "                    internet, scholarship, part_time, stress, semester, dept, par_edu, gpa):\n",
        "\n",
        "    inp = pd.DataFrame([{\n",
        "        'Age': age, 'CGPA': cgpa, 'Semester_GPA': semester_gpa,\n",
        "        'Study_Hours_per_Day': study_h, 'Assignment_Delay_Days': delay,\n",
        "        'Attendance_Rate': attendance, 'Travel_Time_Minutes': travel,\n",
        "        'Internet_Access': 1 if internet=='Yes' else 0,\n",
        "        'Scholarship': 1 if scholarship=='Yes' else 0,\n",
        "        'Part_Time_Job': 1 if part_time=='Yes' else 0,\n",
        "        'Stress_Index': stress, 'Parental_Education': par_edu,\n",
        "    }])\n",
        "\n",
        "    # Feature engineering\n",
        "    inp['Dept_Semester']          = dept + '_' + semester\n",
        "    inp['Income_Stress_Ratio']    = stress / (30000 + 1)\n",
        "    inp['GPA_vs_CGPA']            = gpa - cgpa\n",
        "    inp['GPA_vs_SGPA']            = gpa - semester_gpa\n",
        "    inp['Job_Stress_Interaction'] = inp['Part_Time_Job'] * stress\n",
        "    inp['Student_Pressure_Index'] = (delay + travel + inp['Part_Time_Job'].values[0] + stress) / (attendance + study_h + 0.01)\n",
        "    inp['Academic_Risk']          = int(attendance<75) + int(study_h<2) + int(delay>5)\n",
        "    inp['GPA_Stress_Ratio']       = gpa / (stress + 1)\n",
        "    inp['Attendance_Study']       = attendance * study_h\n",
